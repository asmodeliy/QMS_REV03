/* RPMT CSS */

/* ===== rpmt.css ===== */
/* Uses CSS variables from shared.css */

.rpmt-root {
  --pc: #667eea;
  --bg: #ffffff;
}

/* Admin Layout */
.admin-wrap {
  min-height: 100vh;
  background: #f5f6fa;
  padding: 0;
}

.admin-layout {
  display: grid;
  grid-template-columns: 320px 1fr;
  gap: 0;
  min-height: calc(100vh - 60px);
}

.admin-layout .sidebar {
  background: white;
  border-right: 1px solid #e5e7eb;
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  overflow-y: auto;
}

.admin-layout .side-head {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.admin-layout .side-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
  max-height: 50vh;
  overflow-y: auto;
}

.admin-layout .side-item {
  padding: 12px 14px;
  border-radius: 8px;
  border: 1px solid #e5e7eb;
  background: white;
  cursor: pointer;
  transition: all 0.2s;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 8px;
}

.admin-layout .side-item:hover {
  background: #f9fafb;
  border-color: var(--pc);
  transform: translateX(4px);
}

.admin-layout .side-item.active {
  background: linear-gradient(135deg, rgba(102,126,234,0.1), rgba(118,75,162,0.05));
  border-color: var(--pc);
  box-shadow: 0 2px 6px rgba(102,126,234,0.15);
}

.admin-layout .side-item .row {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6px;
  min-width: 0;
}

.admin-layout .side-item .code {
  font-weight: 600;
  color: #1e293b;
}

.admin-layout .detail {
  padding: 24px;
  overflow-y: auto;
}

.admin-layout .detail .empty-hint {
  text-align: center;
  color: #94a3b8;
  font-size: 18px;
  padding: 60px 20px;
}

.admin-layout .detail .loading {
  text-align: center;
  color: #667eea;
  font-size: 16px;
  padding: 40px 20px;
}

.admin-layout .detail .error {
  text-align: center;
  color: #ef4444;
  font-size: 14px;
  padding: 40px 20px;
  background: #fef2f2;
  border-radius: 8px;
  border: 1px solid #fca5a5;
}

.create-form {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 16px;
  background: #f9fafb;
  border-radius: 8px;
  border: 1px solid #e5e7eb;
}

.create-form .title-sm {
  font-size: 14px;
  font-weight: 600;
  color: #334155;
  margin-bottom: 4px;
}

/* Admin Panel (system status) */
.admin-panel {
  background: white;
  border-radius: 12px;
  padding: 24px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}

.admin-panel .panel-head {
  margin-bottom: 24px;
  padding-bottom: 16px;
  border-bottom: 2px solid #f1f5f9;
}

.admin-panel .panel-head h2 {
  margin: 0 0 8px 0;
  color: #1e293b;
  font-size: 24px;
}

.admin-panel .panel-head .muted {
  margin: 0;
  color: #64748b;
  font-size: 14px;
}

.sys-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 16px;
}

.sys-card {
  padding: 20px;
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  border-radius: 10px;
  border: 1px solid #e2e8f0;
}

.sys-card.wide {
  grid-column: 1 / -1;
}

.sys-card .label {
  font-size: 12px;
  font-weight: 600;
  color: #64748b;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 8px;
}

.sys-card .value {
  font-size: 24px;
  font-weight: 700;
  color: var(--pc);
  margin-bottom: 4px;
}

.sys-card .value.small {
  font-size: 14px;
  font-weight: 500;
  color: #475569;
  word-break: break-all;
}

.sys-card .hint {
  font-size: 12px;
  color: #94a3b8;
}

@media (max-width: 1024px) {
  .admin-layout {
    grid-template-columns: 280px 1fr;
  }
}

@media (max-width: 768px) {
  .admin-layout {
    grid-template-columns: 1fr;
  }
  
  .admin-layout .sidebar {
    border-right: none;
    border-bottom: 1px solid #e5e7eb;
  }
}

/* Admin Top Bar */
.admin-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 24px;
  background: white;
  border-bottom: 2px solid #e5e7eb;
  margin-bottom: 0;
}

.admin-top .brand a {
  display: inline-block;
  padding: 10px 18px;
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  border-radius: 8px;
  color: var(--pc);
  text-decoration: none;
  font-weight: 600;
  transition: all 0.2s ease;
  border: 1px solid #e2e8f0;
}

.admin-top .brand a:hover {
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
  border-color: var(--pc);
  transform: translateY(-2px);
  box-shadow: 0 4px 8px rgba(102,126,234,0.15);
}

.admin-top .toolbar {
  display: flex;
  gap: 10px;
  align-items: center;
  flex-wrap: wrap;
}

.admin-top .toolbar .btn {
  padding: 10px 16px;
  font-size: 14px;
  font-weight: 500;
  border-radius: 6px;
  transition: all 0.2s;
}

/* Admin Cards & Tables */
.admin-card {
  background: white;
  border-radius: 10px;
  padding: 20px;
  margin-bottom: 20px;
  box-shadow: 0 2px 6px rgba(0,0,0,0.06);
  border: 1px solid #e5e7eb;
}

.admin-card.soft {
  background: #fafbfc;
}

.admin-card-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 2px solid #f1f5f9;
}

.admin-title {
  font-size: 20px;
  font-weight: 700;
  color: var(--pc);
}

.table-form-grid {
  display: grid;
  gap: 12px;
  margin-bottom: 20px;
}

.table-form-grid.cols-6 {
  grid-template-columns: repeat(5, 1fr) auto;
}

/* Admin Task Table - 최적화된 컬럼 너비 */
.admin-task-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
}

.admin-task-table thead tr:first-child th {
  background: rgba(102, 126, 234, 0.08);
  color: #4a5568;
  padding: 12px;
  text-align: left;
  font-weight: 600;
}

.admin-task-table thead tr:last-child th {
  background: #f8fafc;
  color: #64748b;
  font-weight: 600;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  padding: 10px 8px;
  border-bottom: 2px solid #e2e8f0;
  white-space: nowrap;
}

.admin-task-table tbody tr {
  border-bottom: 1px solid #e5e7eb;
}

.admin-task-table tbody tr:hover {
  background: #f9fafb;
}

/* 컬럼별 너비 최적화 - FROM/TO 축소, TASK 확대 */
.admin-task-table thead tr:last-child th:nth-child(1) { width: 12%; } /* CATEGORY */
.admin-task-table thead tr:last-child th:nth-child(2) { width: 25%; } /* TASK - 넓게 */
.admin-task-table thead tr:last-child th:nth-child(3) { width: 8%; }  /* FROM - 축소 */
.admin-task-table thead tr:last-child th:nth-child(4) { width: 8%; }  /* TO - 축소 */
.admin-task-table thead tr:last-child th:nth-child(5) { width: 10%; } /* DUE */
.admin-task-table thead tr:last-child th:nth-child(6) { width: 12%; } /* STATUS */
.admin-task-table thead tr:last-child th:nth-child(7) { width: 6%; }  /* ORD */
.admin-task-table thead tr:last-child th:nth-child(8) { width: 19%; } /* ACTIONS */

.admin-task-table tbody td {
  padding: 6px 8px;
  vertical-align: middle;
}

.admin-task-table tbody td .inp {
  width: 100%;
  padding: 6px 8px;
  border: 1px solid #cbd5e1;
  border-radius: 4px;
  font-size: 12px;
  background: white;
  transition: border-color 0.2s;
}

.admin-task-table tbody td .inp:focus {
  outline: none;
  border-color: var(--pc);
  box-shadow: 0 0 0 2px rgba(102,126,234,0.1);
}

.admin-task-table .actions-cell {
  display: flex;
  gap: 4px;
  align-items: center;
  flex-wrap: wrap;
  padding: 4px;
}

.admin-task-table .category-header {
  padding: 10px 12px !important;
}

@media (max-width: 1400px) {
  .admin-task-table {
    font-size: 12px;
  }
  
  .admin-task-table thead tr:last-child th:nth-child(2) { width: 22%; } /* TASK */
  .admin-task-table thead tr:last-child th:nth-child(3) { width: 7%; }  /* FROM */
  .admin-task-table thead tr:last-child th:nth-child(4) { width: 7%; }  /* TO */
}



.rpmt-root .dashboard-header-section {
  background: var(--bg);
  color: var(--pc);
  border-top: 4px solid var(--pc);
}

.rpmt-header {
  background: transparent;
  border: 0;
}

.rpmt-header .dashboard-title {
  color: #667eea;
  font-weight:800
}

.rpmt-header .header-actions {
  display:flex;
  gap:12px;
  align-items:center
}

.rpmt-root.detail-shell {
  background: #f8f9fb;
  min-height: 100vh;
}

.rpmt-root.detail-shell .page-head {
  background: white;
  border-radius: 12px;
  padding: 28px 32px;
  margin: 0 0 24px 0;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}

.rpmt-root.detail-shell .page-head .title {
  color: #1a202c;
  font-size: 32px;
}

.rpmt-root .meta-split {
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:14px;
  align-items:start;
  min-height:0;
}

.rpmt-root .focus-card {
  background:var(--card-bg);
  border-radius:var(--card-radius);
  border:1px solid var(--divider);
  box-shadow:var(--card-shadow);
  padding:14px 16px;
  display:flex;
  flex-direction:column;
  min-height:220px;
}

.rpmt-root .focus-item {
  border-radius:10px;
  padding:8px 10px;
  border:1px solid rgba(148,163,184,.5);
  background:linear-gradient(135deg, rgba(248,250,252,.95), rgba(241,245,249,.98));
}

.rpmt-root .focus-item .fi-main {
  display:flex;
  align-items:center;
  flex-wrap:wrap;
  gap:4px;
  font-size:13px
}

.rpmt-root .focus-item .fi-prj {
  font-weight:600;
  color:#0b1933;
  text-decoration:none
}

.rpmt-root .focus-item .fi-meta {
  margin-top:4px;
  display:flex;
  flex-wrap:wrap;
  gap:4px;
  font-size:11px
}

@media (max-width: 1200px) {
  .rpmt-root .container,
  .rpmt-root .container.wide {
  width:100%;
  padding:12px
}

.rpmt-root .cards {
  grid-template-columns:repeat(auto-fit, minmax(260px, 1fr));
}

}

.rpmt-root .cards {
  display:grid;
  gap:16px;
  grid-template-columns:repeat(auto-fit, minmax(300px, 1fr));
  align-items:stretch
}

.rpmt-root .card {
  background:var(--card-bg);
  border:1px solid var(--divider);
  border-radius:var(--card-radius);
  box-shadow:var(--card-shadow);
  transition:box-shadow .18s ease, transform .18s ease, border-color .18s ease;
  padding:14px 14px;
  display:grid;
  grid-template-rows:auto auto 1fr;
  min-height:160px;
  position:relative;
}

.rpmt-root .card-title {
  font-weight:700;
  font-size:15px;
  color:#0b1933;
  text-decoration:none;
  display:inline-block;
  max-width:100%;
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
}

.rpmt-root .card-title {
  transition: color .14s ease, background .14s ease, transform .14s ease;
}

.rpmt-root .card-title:hover {
  text-decoration:none;
  color:#0b1933;
  background: rgba(99,102,241,0.06);
  padding:2px 6px;
  border-radius:6px;
  transform: translateY(-2px);
}

.rpmt-root .card-title[title] {
  cursor:default;
}

.rpmt-root .card::before {
  content: '';
  position: absolute;
  background: linear-gradient(180deg, color-mix(in oklab, var(--pc) 14%, #fff), #fff);
  border-bottom:1px solid var(--divider);
}

.rpmt-root .ps-title {
  margin:0;
  font-weight:800;
  font-size:15px;
  letter-spacing:.01em
}

.rpmt-root .logout-link {
  font-size:13px;
}

.rpmt-root .head-actions {
  display:flex;
  gap:12px
}

.rpmt-root .head-filters {
  display:flex;
  align-items:center;
  gap:16px;
  flex-wrap:wrap
}

.rpmt-root .gf-row.inline {
  margin:0 10px 0 0
}

.rpmt-root .gf-checkbox.inline {
  margin-left:4px
}

.rpmt-root .global-filters {
  display:flex;
  justify-content:space-between;
  align-items:flex-start;
  gap:16px;
  margin:12px auto 4px;
  padding:10px 14px;
  max-width:clamp(1100px,92vw,2400px);
  background:#fff;
  border-radius:12px;
  border:1px solid var(--divider);
  box-shadow:0 4px 12px rgba(15,23,42,.04);
}

.rpmt-root .global-filters-left {
  display:flex;
  flex-direction:column;
  gap:4px
}

.rpmt-root .gf-title {
  font-size:13px;
  color:#0f172a;
  margin-bottom:2px
}

.rpmt-root .gf-row.inline .gf-label {
  margin-right:1px
}

.rpmt-root .gf-select {
  min-width:140px
}

.rpmt-root .gf-input {
  min-width:200px
}

.rpmt-root .global-filters-right {
  display:flex;
  align-items:center;
  gap:10px;
  font-size:13px;
  color:var(--muted)
}

#delayModal, .rpmt-root .modal.delay, .rpmt-root #delayModal {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

#delayModal .modal-overlay, .rpmt-root .modal-overlay {
  position: absolute;
  inset: 0;
  background: rgba(2,6,23,0.48);
  z-index: 9998;
}

#delayModal .modal-card, .rpmt-root .modal-card {
  position: relative;
  z-index: 9999;
  width: min(920px, 96vw);
  max-height: 88vh;
  overflow: hidden;
  background: var(--card-bg);
  border-radius: var(--card-radius);
  box-shadow: var(--card-shadow);
  display: flex;
  flex-direction: column;
}

#delayModal .modal-body {
  padding: 14px 18px;
  max-height: 68vh;
  overflow:auto;
}

#delayModal .modal-head, #delayModal .modal-foot {
  padding:14px 16px;
}

#delayModal .modal-card, #delayModal .modal-card * {
  pointer-events: auto !important;
}

#delayModal .modal-overlay {
  pointer-events: auto !important;
}

#delayModal .modal-head .tit, #delayModal .modal-head strong {
  font-weight:700;
  color:#10232a;
}

#delayModal .modal-head .icon-btn.danger {
  background:#ef4444;
  color:#fff;
  border:none;
}

#delayModal .delay-list {
  list-style:none;
  margin:0;
  padding:0;
  display:block;
  max-height:64vh;
  overflow:auto;
}

#delayModal .delay-item {
  background: #fff;
  border:1px solid rgba(15,23,42,0.04);
  padding:10px;
  margin:8px 12px;
  border-radius:8px;
}

#delayModal .modal-foot {
  display:flex;
  justify-content:flex-end;
  gap:8px;
  border-top:1px solid rgba(15,23,42,0.04);
  padding:12px 16px;
}

#delayModal .modal-foot .btn.primary, #delayModal .modal-foot .btn.primary {
  background: linear-gradient(135deg, #2563eb, #1e40af) !important;
  color:#fff !important;
  box-shadow:0 8px 20px rgba(37,99,235,0.18) !important;
}

.rpmt-root .delay-list {
  list-style:none;
  margin:0;
  padding:0;
  display:grid;
  gap:10px
}

.rpmt-root .delay-item {
  border:1px solid var(--divider);
  border-radius:10px;
  padding:10px 12px;
  background:var(--brand-50)
}

.rpmt-root .icon-btn {
  width: 32px;
  height: 32px;
  padding: 0;
  border: none;
  background: transparent;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 6px;
  font-size: 18px;
  transition: all 0.2s ease;
}

.rpmt-root .detail-side {
  background:#fff;
  border:1px solid var(--divider);
  border-radius:16px;
  box-shadow:var(--card-shadow);
  padding:14px 12px;
  overflow:hidden;
}

.rpmt-root .detail-side .ps-head {
  padding:10px 12px;
  margin:0 0 10px 0;
  border-bottom:1px solid var(--divider);
}

.rpmt-root .detail-side .ps-title {
  font-size:14px;
  margin:0;
  font-weight:700
}

.rpmt-root .detail-side .ps-tags {
  padding:8px 0 10px;
  display:flex;
  gap:8px;
  flex-wrap:wrap
}

.rpmt-root .detail-side .ps-pill {
  font-size:12px;
  padding:6px 10px;
  border-radius:999px
}

.rpmt-root .detail-side .ps-kpis {
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:8px;
  padding:8px 0
}

.rpmt-root .detail-side .ps-kpi {
  background:transparent;
  border:1px solid var(--divider);
  padding:8px 10px;
  border-radius:10px
}

.rpmt-root .detail-side .ps-kv {
  padding-top:10px;
  display:grid;
  grid-template-columns:120px 1fr;
  gap:6px 10px
}

.rpmt-root .detail-side .ps-progress {
  padding-top:10px
}

.rpmt-root .project-hero {
  height:44px;
  margin:6px 0 14px;
  border-radius:14px;
  background: linear-gradient(180deg, var(--pc-50), #fff);
  border: 1px solid var(--pc-200);
  box-shadow: var(--card-shadow);
}

.rpmt-root .ps-actions {
  padding:12px 16px;
  display:flex;
  gap:8px;
  border-top:1px dashed var(--divider)
}

.rpmt-root .attach-list {
  display:flex;
  gap:6px;
  flex-wrap:wrap;
  align-items:center;
}

.rpmt-root .attach-item {
  display:inline-flex;
  align-items:center;
  gap:6px;
  padding:6px 10px;
  background:#f3f4f6;
  border-radius:8px;
  font-size:12px;
  text-decoration:none;
  color:#1f2937;
  transition:all .15s ease;
  border:1px solid transparent;
  font-weight:500;
}

.rpmt-root .file-input-wrapper {
  position:relative;
  display:inline-flex;
}

.rpmt-root .file-input-label {
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:6px;
  height:36px;
  padding:0 12px;
  background:#fff;
  border:1px dashed var(--stroke);
  border-radius:9px;
  cursor:pointer;
  font-size:12px;
  font-weight:500;
  color:var(--brand-700);
  transition:all .15s ease;
}

.rpmt-root .btn-preview {
  padding: 5px 2px !important;
  background: #f0f4ff !important;
  color: var(--brand-600, #2e5bff) !important;
  border: 1px solid #d6e0ff !important;
  border-radius: 6px !important;
  cursor: pointer !important;
  font-size: 13px !important;
  transition: all .15s ease !important;
  font-weight: 500 !important;
}

.rpmt-root .btn-delete {
  padding: 5px 2px !important;
  background: #f0f4ff !important;
  color: var(--brand-600, #2e5bff) !important;
  border: 1px solid #d6e0ff !important;
  border-radius: 6px !important;
  cursor: pointer !important;
  font-size: 13px !important;
  transition: all .15s ease !important;
  font-weight: 500 !important;
}

.rpmt-root .task-table {
  width: 100%;
  border-collapse: collapse;
  margin: 0;
  font-size: 13px;
  background: #fff;
  border-radius: 0;
}

.rpmt-root .task-table {
  table-layout: fixed;
}

.rpmt-root .task-table .col-status .sel,
.rpmt-root .task-table .col-remark .inp {
  width: 100%;
  box-sizing: border-box;
}

.rpmt-root .task-table {
  table-layout: fixed;
}

.rpmt-root .task-table th:last-child,
.rpmt-root .task-table td:last-child {
  border-right: none;
}

.rpmt-root .task-table .col-status .sel,
.rpmt-root .task-table .col-remark .inp {
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
}

.rpmt-root .task-table th,
.rpmt-root .task-table td {
  padding: 10px 12px;
  vertical-align: middle;
  word-break: break-word;
}

.rpmt-root .cat {
  background: var(--card-bg);
  border: 1px solid var(--divider);
  border-radius: 12px;
  box-shadow: var(--card-shadow);
  overflow: hidden;
}

.rpmt-root .cat .task-table thead th {
  background: transparent;
