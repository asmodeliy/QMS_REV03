@keyframes pulse-glow {
  0%, 100% {
  background: #fff5f5;
  border-color: #f4a5a5;
  box-shadow: 0 3px 10px rgba(15,23,42,.05), 0 0 12px rgba(209, 75, 75, 0.2);
}

50% {
  background: #ffecec;
  border-color: #f08888;
  box-shadow: 0 3px 10px rgba(15,23,42,.05), 0 0 20px rgba(209, 75, 75, 0.35);
}

}

.week-item[data-delayed="true"] {
  animation: pulse-glow 2s ease-in-out infinite;
  border: 2px solid #f08888 !important;
}

.week-item[data-delayed="true"] .chip.danger {
  background: linear-gradient(135deg, #d14b4b, #e85050) !important;
  color: #fff !important;
  font-weight: 700;
  box-shadow: 0 2px 8px rgba(209, 75, 75, 0.3);
}

.chip.danger.pulse {
  animation: pulse-icon 2s ease-in-out infinite;
}

@keyframes pulse-icon {
  0%, 100% {
  transform: scale(1);
}

50% {
  transform: scale(1.05);
}

}

.wk2-grid-inner {
  display:grid;
  grid-auto-flow:column;
  grid-template-rows:auto;
  grid-auto-columns:minmax(180px,1fr);
  font-weight:800;
  margin:0;
  color:#0b1933;
}

