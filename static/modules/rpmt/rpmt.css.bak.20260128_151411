* Project Color Binding*/
.pcol.variant-1 {
  --pc:var(--v1);
  --pc-50:var(--v1-50);
  --pc-200:var(--v1-200);
}

.pcol.variant-2 {
  --pc:var(--v2);
  --pc-50:var(--v2-50);
  --pc-200:var(--v2-200);
}

.pcol.variant-3 {
  --pc:var(--v3);
  --pc-50:var(--v3-50);
  --pc-200:var(--v3-200);
}

.pcol.variant-4 {
  --pc:var(--v4);
  --pc-50:var(--v4-50);
  --pc-200:var(--v4-200);
}

.pcol.variant-5 {
  --pc:var(--v5);
  --pc-50:var(--v5-50);
  --pc-200:var(--v5-200);
}

.pcol.variant-6 {
  --pc:var(--v6);
  --pc-50:var(--v6-50);
  --pc-200:var(--v6-200);
}

.pcol.variant-7 {
  --pc:var(--v7);
  --pc-50:var(--v7-50);
  --pc-200:var(--v7-200);
}

.pcol.variant-8 {
  --pc:var(--v8);
  --pc-50:var(--v8-50);
  --pc-200:var(--v8-200);
}

.cell.head.pcol {
  border-color:var(--pc-200);
  background:linear-gradient(180deg,var(--pc-50),#fff);
  color:var(--pc);
  position:relative;
  padding-top:18px;
}

.cell.head.pcol::before {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 6px;
  border-top-left-radius: 12px;
  border-top-right-radius: 12px;
  background: linear-gradient(90deg, var(--pc), color-mix(in srgb, var(--pc) 60%, #fff 40%));
  box-shadow: 0 2px 6px rgba(0,0,0,0.04);
}

.cell.body.pcol {
  border-color:var(--pc-200);
  background: linear-gradient(180deg,#fff, var(--pc-50, transparent));
}

.cell.pcol .chip {
  background: var(--pc-50);
  border-color: var(--pc-200);
  color: var(--pc);
  font-weight:600;
  padding:4px 8px;
  border-radius:8px;
  font-size:11px;
}

.wk2-task {
  display:block;
  border:1px solid var(--divider);
  border-radius:10px;
  padding:10px;
  margin:10px 0;
  background:#fff;
  box-shadow: 0 6px 18px rgba(9,30,66,0.04);
  transition:transform .12s ease, box-shadow .12s ease;
}

.wk2-task:hover {
  transform:translateY(-4px);
  box-shadow: 0 12px 30px rgba(9,30,66,0.08);
  border-color: rgba(2,14,34,.08);
}

.cell.pcol .wk2-task {
