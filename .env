export LLM_N_CTX=4096
export LLM_BACKEND=gpt4all
export LLM_MODEL_PATH=C:\Users\이상원\Downloads\Models    # directory containing your .gguf files
export LLM_MODEL_NAME=Meta-Llama-3-8B-Instruct.Q5_K_M # model id or base filename (without .gguf)
export LLM_MODEL_TYPE=gguf
export LLM_ALLOW_DOWNLOAD=0                      # set 0 to avoid network downloads
export LLM_DEVICE=cpu
export LLM_VERBOSE=1
export LLM_DISABLE_LLAMA=0
export LLM_GPU_DEVICE=cpu  