export LLM_N_CTX=2048
export LLM_BACKEND=gpt4all
export LLM_MODEL_PATH=/home/ronnie/llm/models    # directory containing your .gguf files
export LLM_MODEL_NAME=gpt4all-falcon-newbpe-q4_0 # model id or base filename (without .gguf)
export LLM_MODEL_TYPE=gguf
export LLM_ALLOW_DOWNLOAD=0                      # set 0 to avoid network downloads
export LLM_DEVICE=cpu
export LLM_VERBOSE=1
export LLM_DISABLE_LLAMA=1  