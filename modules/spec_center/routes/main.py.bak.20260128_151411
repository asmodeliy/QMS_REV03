@router.get('/api/categories')
def get_categories(request: Request, db: Session = Depends(get_spec_db)):
    """Get hierarchical category structure"""
    try:
        root_cats = db.query(SpecCategory).filter(
            SpecCategory.parent_id == None,
            SpecCategory.is_active == True
        ).order_by(SpecCategory.order, SpecCategory.name).all()
        
        def serialize_category(cat):
            children = db.query(SpecCategory).filter(
                SpecCategory.parent_id == cat.id,
                SpecCategory.is_active == True
            ).order_by(SpecCategory.order, SpecCategory.name).all()
            
            files = db.query(SpecFile).filter(
                SpecFile.category_id == cat.id,
                SpecFile.is_active == True
            ).order_by(SpecFile.order, SpecFile.original_name).all()
            
            return {
                'id': cat.id,
                'name': cat.name,
                'description': cat.description,
                'icon': cat.icon or '?',
                'children': [serialize_category(c) for c in children],
                'files': [
                    {
                        'id': f.id,
                        'filename': f.filename,
                        'original_name': f.original_name,
                        'file_type': f.file_type,
                        'size': f.file_size,
                        'description': f.description
                    }
                    for f in files
                ]
            }
        
        result = [serialize_category(cat) for cat in root_cats]
        return JSONResponse(result)
    except Exception as e:
        spec_logger.exception(f"Error fetching categories: {e}")
        raise HTTPException(status_code=500, detail=str(e))


