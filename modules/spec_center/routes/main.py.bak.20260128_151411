@router.get('/api/files/search')
def search_files(request: Request, q: str, limit: int = 20, db: Session = Depends(get_spec_db)):
    """Search active files by original_name or filename. Returns basic info and category path."""
    ensure_templates()
    try:
        query = (q or '').strip()
        if not query:
            return {"items": [], "total": 0}

        like = f"%{query}%"
        files = (
            db.query(SpecFile, SpecCategory)
            .join(SpecCategory, SpecFile.category_id == SpecCategory.id)
            .filter(
                SpecFile.is_active == True,
                SpecCategory.is_active == True,
                (SpecFile.original_name.ilike(like)) | (SpecFile.filename.ilike(like))
            )
            .order_by(SpecFile.created_at.desc())
            .limit(max(1, min(100, limit)))
            .all()
        )

        def build_cat_path(cat: SpecCategory) -> str:
            names = []
            current = cat
            safety = 0
            while current and safety < 50:
                names.append(current.name or '')
                if not current.parent_id:
                    break
                current = db.query(SpecCategory).filter(SpecCategory.id == current.parent_id).first()
                safety += 1
            return ' / '.join(reversed([n for n in names if n]))

        items = []
        for f, c in files:
            items.append({
                'id': f.id,
                'filename': f.filename,
                'original_name': f.original_name,
                'file_type': f.file_type,
                'size': f.file_size,
                'category_id': f.category_id,
                'category_path': build_cat_path(c),
                'created_at': f.created_at.isoformat(),
            })

        return {"items": items, "total": len(items), "q": query}
    except Exception as e:
        spec_logger.exception(f"Error searching files: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@router.post('/api/files/{file_id:int}/convert')
def convert_file(file_id: int, db: Session = Depends(get_spec_db)):
    """Convert file to PDF for preview"""
    try:
        file = db.query(SpecFile).filter(SpecFile.id == file_id).first()
        if not file:
            raise HTTPException(status_code=404, detail="File not found")
        
        filename = file.filename
        ext = Path(filename).suffix.lower().lstrip('.')
        
        if ext == 'pdf':
            return JSONResponse({"success": True, "message": "Already PDF"})
        
        pdfname = str(Path(filename).with_suffix('.pdf'))
        pdfpath = UPLOAD_FOLDER / pdfname
        if pdfpath.exists():
            return JSONResponse({"success": True, "message": "PDF already exists"})
        
        path = UPLOAD_FOLDER / filename
        if not path.exists():
            raise HTTPException(status_code=404, detail="File not found on disk")
        
        if ext in ('doc', 'docx', 'ppt', 'pptx', 'xlsx', 'xls'):
            if platform.system().lower().startswith('win') and ext in ('doc', 'docx'):
                try:
                    spec_logger.info(f"Converting {filename} to PDF via Word COM")
                    src_abs = path.resolve()
                    dst_abs = pdfpath.resolve()
                    
                    ps_script = f"""$ErrorActionPreference = 'Stop'
try {{
    $word = New-Object -ComObject Word.Application
    $word.Visible = $false
    $doc = $word.Documents.Open('{src_abs}')
    $doc.SaveAs('{dst_abs}', 17)
    $doc.Close($false)
    $word.Quit()
    [System.Runtime.Interopservices.Marshal]::ReleaseComObject($word) | Out-Null
    exit 0
}} catch {{
    Write-Error $_.Exception.Message
    exit 1
}}"""
                    
                    res = subprocess.run(['powershell', '-NoProfile', '-NonInteractive', '-Command', ps_script], 
                                       check=False, capture_output=True, timeout=120, text=True)
                    
                    if res.returncode == 0 and pdfpath.exists():
                        spec_logger.info(f"Successfully converted {filename} to PDF")
                        return JSONResponse({"success": True, "message": "Converted to PDF"})
                    else:
                        spec_logger.error(f"Conversion failed: {res.stderr}")
                        raise HTTPException(status_code=500, detail=f"Conversion failed: {res.stderr}")
                except subprocess.TimeoutExpired:
                    raise HTTPException(status_code=500, detail="Conversion timeout")
                except Exception as e:
                    spec_logger.exception(f"Conversion error: {e}")
                    raise HTTPException(status_code=500, detail=str(e))
            
            elif platform.system().lower().startswith('win') and ext in ('ppt', 'pptx'):
                try:
                    spec_logger.info(f"Converting {filename} to PDF via PowerPoint COM")
                    src_abs = path.resolve()
                    dst_abs = pdfpath.resolve()
                    
                    ps_script = f"""$ErrorActionPreference = 'Stop'
try {{
    $ppt = New-Object -ComObject PowerPoint.Application
    $pres = $ppt.Presentations.Open('{src_abs}', $true, $true, $false)
    $pres.SaveAs('{dst_abs}', 32)
    $pres.Close()
    $ppt.Quit()
    [System.Runtime.Interopservices.Marshal]::ReleaseComObject($ppt) | Out-Null
    exit 0
}} catch {{
    Write-Error $_.Exception.Message
    exit 1
}}"""
                    
                    res = subprocess.run(['powershell', '-NoProfile', '-NonInteractive', '-Command', ps_script], 
                                       check=False, capture_output=True, timeout=120, text=True)
                    
                    if res.returncode == 0 and pdfpath.exists():
                        spec_logger.info(f"Successfully converted {filename} to PDF")
                        return JSONResponse({"success": True, "message": "Converted to PDF"})
                    else:
                        spec_logger.error(f"Conversion failed: {res.stderr}")
                        raise HTTPException(status_code=500, detail=f"Conversion failed: {res.stderr}")
                except subprocess.TimeoutExpired:
                    raise HTTPException(status_code=500, detail="Conversion timeout")
                except Exception as e:
                    spec_logger.exception(f"Conversion error: {e}")
                    raise HTTPException(status_code=500, detail=str(e))
        
        raise HTTPException(status_code=400, detail="Unsupported file type for conversion")
    except HTTPException:
        raise
    except Exception as e:
        spec_logger.exception(f"Error in convert_file: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@router.get('/api/files/{file_id:int}/excel-preview')
def excel_preview(request: Request, file_id: int, db: Session = Depends(get_spec_db)):
    """Excel 파일을 HTML 테이블로 미리보기 (스타일 일부 보존)"""
    ensure_templates()
    try:
        if not HAS_OPENPYXL:
            raise HTTPException(status_code=400, detail="openpyxl not installed")

        spec_file = db.query(SpecFile).filter(SpecFile.id == file_id).first()
        if not spec_file:
            raise HTTPException(status_code=404, detail="File not found")

        ext = (spec_file.file_type or '').lower()
        if ext not in ('xlsx', 'xls'):
            raise HTTPException(status_code=400, detail="Not an Excel file")

        path = UPLOAD_FOLDER / spec_file.filename
        if not path.exists():
            raise HTTPException(status_code=404, detail="File not found on disk")

        wb_values = load_workbook(path, data_only=True)
        wb_styles = load_workbook(path)
        sheet_names = wb_values.sheetnames

        def render_sheet_html(sheet_name: str) -> str:
            ws_vals = wb_values[sheet_name]
            ws_styles = wb_styles[sheet_name]
            rows_html = []
            for r_idx, row in enumerate(ws_vals.iter_rows(values_only=False), 1):
                row_html = '<tr>'
                for c_idx, cell in enumerate(row, 1):
                    tag = 'th' if r_idx == 1 else 'td'
                    val = cell.value
                    content = ('' if val is None else str(val))
                    content = content.replace('&','&amp;').replace('<','&lt;').replace('>','&gt;')

                    styles = []
                    try:
                        st_cell = ws_styles.cell(row=r_idx, column=c_idx)
                        fill = getattr(st_cell, 'fill', None)
                        if fill and fill.start_color and fill.start_color.rgb:
                            rgb = str(fill.start_color.rgb)
                            if len(rgb) >= 8:
                                hex_color = rgb[-6:]
                                if hex_color and hex_color.lower() != '000000':
                                    styles.append(f'background-color: #{hex_color};')
                        font = getattr(st_cell, 'font', None)
                        if font:
                            if font.bold:
                                styles.append('font-weight: bold;')
                            if font.italic:
                                styles.append('font-style: italic;')
                            if font.color and font.color.rgb:
                                frgb = str(font.color.rgb)
                                if len(frgb) >= 8:
                                    hex_color = frgb[-6:]
                                    styles.append(f'color: #{hex_color};')
                        align = getattr(st_cell, 'alignment', None)
                        if align:
                            if align.horizontal == 'center':
                                styles.append('text-align: center;')
                            elif align.horizontal == 'right':
                                styles.append('text-align: right;')
                            elif align.horizontal == 'left':
                                styles.append('text-align: left;')
                            if align.vertical == 'center':
                                styles.append('vertical-align: middle;')
                            elif align.vertical == 'top':
                                styles.append('vertical-align: top;')
                            elif align.vertical == 'bottom':
                                styles.append('vertical-align: bottom;')
                    except Exception:
                        pass

                    style_attr = (' style="' + ' '.join(styles) + '"') if styles else ''
                    row_html += f'<{tag}{style_attr}>{content}</{tag}>'
                row_html += '</tr>'
                rows_html.append(row_html)
            return '\n'.join(rows_html)

        tabs_html = []
        sheets_html = []
        for idx, name in enumerate(sheet_names):
            active_tab = 'active' if idx == 0 else ''
            tabs_html.append(f'<button class="sheet-tab {active_tab}" data-sheet="{idx}" onclick="switchSheet({idx})">{name}</button>')
            display = '' if idx == 0 else 'display:none;'
            table_rows = render_sheet_html(name)
            sheets_html.append(f'<div class="sheet-content" data-sheet="{idx}" style="{display}"><table>{table_rows}</table></div>')

        html = f'''<!DOCTYPE html>
<html><head><meta charset="utf-8"><title>{spec_file.original_name}</title>
<style>
*{{margin:0;padding:0;box-sizing:border-box}}body{{font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,sans-serif;padding:20px;background:
.container{{background:
.sheet-tabs{{display:flex;border-bottom:1px solid
.sheet-tab{{padding:12px 16px;background:none;border:none;border-bottom:3px solid transparent;cursor:pointer;font-size:14px;color:
.sheet-tab:hover{{background:
.sheet-content{{padding:20px;overflow-x:auto}}table{{border-collapse:collapse;width:100%;font-size:13px}}th{{background:
</style></head>
<body><div class="container"><div class="filename"><h2>{spec_file.original_name}</h2></div><div class="sheet-tabs">{''.join(tabs_html)}</div><div class="sheet-content-wrap">{''.join(sheets_html)}</div></div>
<script>function switchSheet(i){{document.querySelectorAll('.sheet-content').forEach(function(el){{el.style.display='none'}});document.querySelectorAll('.sheet-tab').forEach(function(el){{el.classList.remove('active')}});document.querySelector('.sheet-content[data-sheet="' + i + '"]').style.display='';document.querySelector('.sheet-tab[data-sheet="' + i + '"]').classList.add('active')}};</script>
</body></html>'''
        return HTMLResponse(html)
    except HTTPException:
