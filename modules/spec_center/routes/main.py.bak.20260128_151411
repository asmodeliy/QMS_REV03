        raise HTTPException(status_code=500, detail=str(e))


@router.get('/api/files/{file_id:int}/preview')
def preview_file_html(request: Request, file_id: int, db: Session = Depends(get_spec_db)):
    """Get preview for a file"""
    ensure_templates()
    try:
        spec_file = db.query(SpecFile).filter(SpecFile.id == file_id).first()
        if not spec_file:
            raise HTTPException(status_code=404, detail="File not found")
        
        filename = spec_file.filename
        ext = spec_file.file_type.lower() if spec_file.file_type else ''

        if ext == 'pdf':
            return templates.TemplateResponse('modules/spec_center/preview_pdf.html', {
                'request': request,
                'filename': filename,
                'file_id': file_id
            })

        pdfname = filename.rsplit('.', 1)[0] + '.pdf'
        pdfpath = UPLOAD_FOLDER / pdfname
        if pdfpath.exists():
            return templates.TemplateResponse('modules/spec_center/preview_pdf.html', {
                'request': request,
                'filename': pdfname,
                'file_id': file_id
            })

        if ext == 'docx':
            return templates.TemplateResponse('modules/spec_center/preview_docx.html', {
                'request': request,
                'filename': filename,
                'file_id': file_id
            })

        if ext in ('doc', 'ppt', 'pptx', 'xlsx', 'xls'):
            path = UPLOAD_FOLDER / filename
            
            if SOFFICE_PATH:
                try:
                    spec_logger.info(f"Attempting soffice conversion for {filename}")
                    res = subprocess.run([SOFFICE_PATH, '--headless', '--convert-to', 'pdf', str(path), '--outdir', str(UPLOAD_FOLDER)], 
                                        check=False, capture_output=True, timeout=60)
                    spec_logger.info(f"soffice convert exit={res.returncode} file={filename}")
                    if res.returncode == 0 and pdfpath.exists():
                        spec_logger.info(f"Successfully converted {filename} to PDF")
                        return templates.TemplateResponse('modules/spec_center/preview_pdf.html', {
                            'request': request,
                            'filename': pdfname,
                            'file_id': file_id
                        })
                except Exception as e:
                    spec_logger.exception(f"soffice convert failed for {filename}: {e}")
            
            if platform.system().lower().startswith('win') and ext in ('doc', 'docx'):
                try:
                    spec_logger.info(f"Attempting Word COM conversion for {filename}")
                    src_abs = path.resolve()
                    dst_abs = pdfpath.resolve()
                    
                    ps_script = f"""$ErrorActionPreference = 'Stop'
try {{
    $word = New-Object -ComObject Word.Application
    $word.Visible = $false
    $doc = $word.Documents.Open('{src_abs}')
    $doc.SaveAs('{dst_abs}', 17)
    $doc.Close($false)
    $word.Quit()
    [System.Runtime.Interopservices.Marshal]::ReleaseComObject($word) | Out-Null
    exit 0
}} catch {{
    Write-Error $_.Exception.Message
    exit 1
}}"""
                    
                    res = subprocess.run(['powershell', '-NoProfile', '-NonInteractive', '-Command', ps_script], 
                                       check=False, capture_output=True, timeout=120, text=True)
                    spec_logger.info(f"Word COM convert exit={res.returncode} file={filename} stderr={res.stderr}")
                    
                    if res.returncode == 0 and pdfpath.exists():
                        spec_logger.info(f"Successfully converted {filename} to PDF via Word COM")
                        return templates.TemplateResponse('modules/spec_center/preview_pdf.html', {
                            'request': request,
                            'filename': pdfname,
                            'file_id': file_id
                        })
                except subprocess.TimeoutExpired:
                    spec_logger.error(f"Word COM conversion timeout for {filename}")
                except Exception as e:
                    spec_logger.exception(f"Word COM convert failed for {filename}: {e}")
            
            if platform.system().lower().startswith('win') and ext in ('ppt', 'pptx'):
                try:
                    spec_logger.info(f"Attempting PowerPoint COM conversion for {filename}")
                    src_abs = path.resolve()
                    dst_abs = pdfpath.resolve()
                    
                    ps_script = f"""$ErrorActionPreference = 'Stop'
try {{
    $ppt = New-Object -ComObject PowerPoint.Application
    $pres = $ppt.Presentations.Open('{src_abs}', $true, $true, $false)
    $pres.SaveAs('{dst_abs}', 32)
    $pres.Close()
    $ppt.Quit()
    [System.Runtime.Interopservices.Marshal]::ReleaseComObject($ppt) | Out-Null
    exit 0
}} catch {{
    Write-Error $_.Exception.Message
    exit 1
}}"""
                    
                    res = subprocess.run(['powershell', '-NoProfile', '-NonInteractive', '-Command', ps_script], 
                                       check=False, capture_output=True, timeout=120, text=True)
                    spec_logger.info(f"PowerPoint COM convert exit={res.returncode} file={filename} stderr={res.stderr}")
                    
                    if res.returncode == 0 and pdfpath.exists():
                        spec_logger.info(f"Successfully converted {filename} to PDF via PowerPoint COM")
                        return templates.TemplateResponse('modules/spec_center/preview_pdf.html', {
                            'request': request,
                            'filename': pdfname,
                            'file_id': file_id
                        })
                except subprocess.TimeoutExpired:
                    spec_logger.error(f"PowerPoint COM conversion timeout for {filename}")
                except Exception as e:
                    spec_logger.exception(f"PowerPoint COM convert failed for {filename}: {e}")

        return templates.TemplateResponse('modules/spec_center/preview_unavailable.html', {
            'request': request,
            'filename': filename,
            'file_id': file_id
        })
    except HTTPException:
        raise
    except Exception as e:
        spec_logger.exception(f"Error previewing file: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@router.get('/serve/{filename:path}')
@router.head('/serve/{filename:path}')
def serve_file(request: Request, filename: str, preview: bool = False):
    """Serve file from uploads/spec_center - preview=true displays inline, otherwise downloads"""
    path = UPLOAD_FOLDER / filename
    client = getattr(request.client, 'host', 'unknown')
    spec_logger.info(f"serve_file request file={filename} client={client} preview={preview} method={request.method}")

    # Direct existence check
    if not path.exists() or not path.is_file():
        # Try unicode normalization (NFC) and case-insensitive fallbacks in the upload folder
        try:
            import unicodedata
            norm_in = unicodedata.normalize('NFC', filename)
            found = None
            for p in UPLOAD_FOLDER.iterdir():
                try:
                    if unicodedata.normalize('NFC', p.name) == norm_in:
                        found = p
                        break
                except Exception:
                    # ignore filenames that can't be normalized
                    continue
            if not found:
                # Last-resort: case-insensitive match
                for p in UPLOAD_FOLDER.iterdir():
                    if p.name.lower() == filename.lower():
                        found = p
                        break
            if found:
                spec_logger.info(f"serve_file fallback matched to on-disk filename: {found.name}")
                path = found
            else:
                # Helpful debug: log a small sample of files in the folder
                sample = [p.name for p in list(UPLOAD_FOLDER.iterdir())[:20]]
                spec_logger.info(f"serve_file not found: {filename}; sample files: {sample}")
                raise HTTPException(status_code=404)
        except HTTPException:
            raise
        except Exception as e:
            spec_logger.exception(f"Error during fallback filename matching: {e}")
            raise HTTPException(status_code=404)

    file_ext = path.suffix.lower()
    media_type_map = {
        '.pdf': 'application/pdf',
        '.docx': 'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
        '.doc': 'application/msword',
        '.pptx': 'application/vnd.openxmlformats-officedocument.presentationml.presentation',
        '.ppt': 'application/vnd.ms-powerpoint',
        '.xlsx': 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',
        '.xls': 'application/vnd.ms-excel',
        '.txt': 'text/plain',
        '.png': 'image/png',
        '.jpg': 'image/jpeg',
        '.jpeg': 'image/jpeg',
        '.gif': 'image/gif',
    }
    media_type = media_type_map.get(file_ext, 'application/octet-stream')
    
    if preview:
        disposition = 'inline'
    else:
        disposition = 'attachment'
    
    encoded_filename = quote(path.name)
    headers = {
        'Content-Disposition': f'{disposition}; filename="{path.name.encode("ascii", "ignore").decode()}"; filename*=UTF-8\'\'{encoded_filename}'
    }
    return FileResponse(path, media_type=media_type, headers=headers)


@router.post('/api/files/{file_id:int}/delete')
def delete_file(request: Request, file_id: int, db: Session = Depends(get_spec_db)):
    """Delete a file (admin only)"""
    if not request.session.get('is_authenticated') or request.session.get('role') != 'Admin':
        raise HTTPException(status_code=401, detail="Unauthorized")

    try:
        spec_file = db.query(SpecFile).filter(SpecFile.id == file_id).first()
        if not spec_file:
            _log_delete('spec_center', f'file_id_{file_id}', request.session.get('email') or 'anon', 
                       getattr(request.client, 'host', 'unknown'), 'not_found')
            return JSONResponse({'ok': False, 'error': 'not found'}, status_code=404)

        path = UPLOAD_FOLDER / spec_file.filename
        if path.exists():
            path.unlink()
            spec_logger.info(f"Deleted file: {spec_file.filename}")

        pdfname = spec_file.filename.rsplit('.', 1)[0] + '.pdf'
        pdfpath = UPLOAD_FOLDER / pdfname
        if pdfpath.exists():
            pdfpath.unlink()

        db.delete(spec_file)
        db.commit()

        _log_delete('spec_center', spec_file.filename, request.session.get('email') or 'anon',
                   getattr(request.client, 'host', 'unknown'), 'deleted')
        return JSONResponse({'ok': True, 'deleted': spec_file.filename})
    except Exception as e:
        spec_logger.exception(f"Error deleting file: {e}")
        _log_delete('spec_center', f'file_id_{file_id}', request.session.get('email') or 'anon',
                   getattr(request.client, 'host', 'unknown'), 'error', str(e))
        return JSONResponse({'ok': False, 'error': str(e)}, status_code=500)


@router.delete('/api/categories/{category_id}')
def delete_category(request: Request, category_id: int, db: Session = Depends(get_spec_db)):
    """Delete a category (admin only)"""
    if not request.session.get('is_authenticated') or request.session.get('role') != 'Admin':
        raise HTTPException(status_code=401, detail="Unauthorized")

    try:
        cat = db.query(SpecCategory).filter(SpecCategory.id == category_id).first()
        if not cat:
            return JSONResponse({'ok': False, 'error': 'not found'}, status_code=404)

        cat.is_active = False
        db.commit()

        spec_logger.info(f"Deactivated category: {cat.name}")
        return JSONResponse({'ok': True, 'deactivated': cat.name})
    except Exception as e:
        spec_logger.exception(f"Error deleting category: {e}")
        return JSONResponse({'ok': False, 'error': str(e)}, status_code=500)

