def _convert_to_pdf_background(src_path: Path):
    """Spawn a background thread to convert src_path to PDF using soffice if available"""
    def worker():
        try:
            pdf_path = src_path.with_suffix('.pdf')
            if pdf_path.exists():
                spec_logger.info(f"pdf already exists for {src_path.name}")
                return

            if SOFFICE_PATH:
                spec_logger.info(f"running soffice conversion for {src_path.name}")
                res = subprocess.run([SOFFICE_PATH, '--headless', '--convert-to', 'pdf', str(src_path), '--outdir', str(UPLOAD_FOLDER)], check=False, capture_output=True, timeout=300)
                try:
                    out = res.stdout.decode('utf-8', errors='replace') if res.stdout else ''
                    err = res.stderr.decode('utf-8', errors='replace') if res.stderr else ''
                except Exception:
                    out = repr(res.stdout); err = repr(res.stderr)
                spec_logger.info(f"soffice background exit={res.returncode} file={src_path.name} out={out!s} err={err!s}")
                return

            if platform.system().lower().startswith('win'):
                spec_logger.info(f"attempting Word COM conversion for {src_path.name}")
                src = str(src_path).replace("'","''")
                dst = str(pdf_path).replace("'","''")
                ps = (
                    "$wd = New-Object -ComObject Word.Application; $wd.Visible = $false;"
                    f" $doc = $wd.Documents.Open('{src}');"
                    f" $doc.SaveAs([ref]'{dst}', [ref]17); $doc.Close(); $wd.Quit();"
                )
                try:
                    res = subprocess.run(['powershell', '-NoProfile', '-NonInteractive', '-Command', ps], check=False, capture_output=True, timeout=300)
                    try:
                        out = res.stdout.decode('utf-8', errors='replace') if res.stdout else ''
                        err = res.stderr.decode('utf-8', errors='replace') if res.stderr else ''
                    except Exception:
                        out = repr(res.stdout); err = repr(res.stderr)
                    spec_logger.info(f"wordcom background exit={res.returncode} file={src_path.name} out={out!s} err={err!s}")
                except Exception as e:
                    spec_logger.exception(f"Word COM conversion failed for {src_path.name}: {e}")
                return

            spec_logger.info(f"no converter available for {src_path.name}")
        except Exception as e:
            spec_logger.exception(f"background conversion worker error for {src_path}: {e}")

    t = threading.Thread(target=worker, daemon=True)
    t.start()


