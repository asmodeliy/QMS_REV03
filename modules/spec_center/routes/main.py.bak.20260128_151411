@router.post('/api/files/upload')
async def upload_file(request: Request, category_id: int, files: List[UploadFile] = File(...), db: Session = Depends(get_spec_db)):
    """Upload one or many files to a category (admin only)"""
    if not request.session.get('is_authenticated') or request.session.get('role') != 'Admin':
        return JSONResponse({'error': 'forbidden'}, status_code=401)

    if not files:
        return JSONResponse({'error': 'no files'}, status_code=400)

    try:
        cat = db.query(SpecCategory).filter(SpecCategory.id == category_id).first()
        if not cat:
            return JSONResponse({'error': 'category not found'}, status_code=404)

        saved = []
        timestamp = datetime.now().strftime('%Y%m%d_%H%M%S_')

        for upload in files:
            if not allowed_file(upload.filename):
                return JSONResponse({'error': f'invalid file type: {upload.filename}'}, status_code=400)

            filename = os.path.basename(upload.filename)
            unique_filename = timestamp + filename
            dest = UPLOAD_FOLDER / unique_filename

            content = await upload.read()
            with open(dest, 'wb') as f:
                f.write(content)

            ext = filename.rsplit('.', 1)[-1].lower()

            spec_file = SpecFile(
                category_id=category_id,
                filename=unique_filename,
                original_name=filename,
                file_size=len(content),
                file_type=ext,
                storage_path=str(dest.relative_to(UPLOAD_FOLDER.parent)),
                uploaded_by=request.session.get('email') or 'anonymous'
            )
            db.add(spec_file)
            db.commit()
            db.refresh(spec_file)

            try:
                _convert_to_pdf_background(dest)
            except Exception:
                spec_logger.exception(f"scheduling background conversion failed for {dest}")

            saved.append({
                'file_id': spec_file.id,
                'filename': unique_filename,
                'original_name': filename
            })

        return JSONResponse({'ok': True, 'uploaded': saved}, status_code=201)
    except Exception as e:
        spec_logger.exception(f"Error uploading file: {e}")
        return JSONResponse({'error': str(e)}, status_code=500)


@router.post('/api/files/move')
async def move_files(request: Request, db: Session = Depends(get_spec_db)):
    """Move one or more files to another category (admin only)"""
    _require_admin(request)

    data = await request.json()
    file_ids = data.get('file_ids') or []
    target_category_id = data.get('target_category_id')

    if not file_ids or not isinstance(file_ids, list):
        raise HTTPException(status_code=400, detail="file_ids must be a non-empty list")
    if not target_category_id:
        raise HTTPException(status_code=400, detail="target_category_id is required")

    try:
        target_cat = db.query(SpecCategory).filter(
            SpecCategory.id == target_category_id,
            SpecCategory.is_active == True
        ).first()
        if not target_cat:
            raise HTTPException(status_code=404, detail="Target category not found")

        moved = 0
        for fid in file_ids:
            spec_file = db.query(SpecFile).filter(
                SpecFile.id == fid,
                SpecFile.is_active == True
            ).first()
            if not spec_file:
                continue
            spec_file.category_id = target_category_id
            spec_file.updated_at = datetime.utcnow()
            moved += 1

        db.commit()
        spec_logger.info(f"files moved count={moved} -> category={target_category_id} user={request.session.get('email')} ip={request.client.host if request.client else 'n/a'}")
        return {"ok": True, "moved": moved, "target_category_id": target_category_id}
    except HTTPException:
        raise
    except Exception as e:
        db.rollback()
        spec_logger.exception(f"Error moving files: {e}")
        raise HTTPException(status_code=500, detail=str(e))


