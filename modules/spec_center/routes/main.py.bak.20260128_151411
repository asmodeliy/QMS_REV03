@router.patch('/api/categories/{category_id}')
async def update_category(request: Request, category_id: int, db: Session = Depends(get_spec_db)):
    """Update category name/description/icon (admin only)"""
    _require_admin(request)

    try:
        data = await request.json()
        cat = db.query(SpecCategory).filter(
            SpecCategory.id == category_id,
            SpecCategory.is_active == True
        ).first()
        if not cat:
            raise HTTPException(status_code=404, detail="Category not found")

        if 'name' in data and data['name'].strip():
            cat.name = data['name'].strip()
        if 'description' in data:
            cat.description = data['description']
        if 'icon' in data:
            cat.icon = data['icon']

        cat.updated_at = datetime.utcnow()
        db.commit()

        spec_logger.info(f"category update id={category_id} user={request.session.get('email')} ip={request.client.host if request.client else 'n/a'}")
        return {"ok": True, "category": {"id": cat.id, "name": cat.name, "description": cat.description, "icon": cat.icon}}
    except HTTPException:
        raise
    except Exception as e:
        db.rollback()
        spec_logger.exception(f"Error updating category {category_id}: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@router.delete('/api/categories/{category_id}')
def delete_category(request: Request, category_id: int, db: Session = Depends(get_spec_db)):
    """Soft-delete a category and all nested children/files (admin only)"""
    _require_admin(request)

    try:
        cat = db.query(SpecCategory).filter(
            SpecCategory.id == category_id,
            SpecCategory.is_active == True
        ).first()
        if not cat:
            raise HTTPException(status_code=404, detail="Category not found")

        def deactivate_category(c: SpecCategory):
            c.is_active = False
            c.updated_at = datetime.utcnow()

            files = db.query(SpecFile).filter(
                SpecFile.category_id == c.id,
                SpecFile.is_active == True
            ).all()
            for f in files:
                f.is_active = False
                f.updated_at = datetime.utcnow()

            children = db.query(SpecCategory).filter(
                SpecCategory.parent_id == c.id,
                SpecCategory.is_active == True
            ).all()
            for child in children:
                deactivate_category(child)

        deactivate_category(cat)
        db.commit()

        spec_logger.info(f"category delete id={category_id} user={request.session.get('email')} ip={request.client.host if request.client else 'n/a'}")
        return {"ok": True, "deleted_category_id": category_id}
    except HTTPException:
        raise
    except Exception as e:
        db.rollback()
        spec_logger.exception(f"Error deleting category {category_id}: {e}")
        raise HTTPException(status_code=500, detail=str(e))


